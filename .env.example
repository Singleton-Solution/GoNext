# GoNext environment variables — comprehensive reference.
#
# Copy this file to .env for local development:
#     cp .env.example .env
#
# The .env file is gitignored. Never commit secrets.
#
# Required variables have no default. The process refuses to boot if any
# required variable is missing. Optional variables have sensible defaults
# documented inline as "Default: ...".
#
# Loader: packages/go/config/load.go. Precedence: process env > defaults.
# Comprehensive prose reference: docs/17-environment.md.
# Secret-management policy: docs/13-security-baseline.md §5.
# Mask the live values via:  gonext config dump

# ============================================================================
# Environment
# ============================================================================

# Deployment environment. One of: development | staging | production | test.
# Unknown values fall back to "development". Affects PublicSite.AllowIndex
# default (production => true; otherwise => false) and is exposed to log
# enrichment + downstream services.
# Default: development
GONEXT_ENV=development

# ============================================================================
# HTTP server (apps/api)
# ============================================================================

# Listen address. Accepts "host:port" or ":port" (binds all interfaces).
# When unset, falls back to PORT, then ":8080".
# Default: ":8080"
# GONEXT_SERVER_ADDR=:8080

# PaaS-style port shorthand (Heroku, Railway, Fly). Honored only when
# GONEXT_SERVER_ADDR is empty; expands to ":<PORT>".
# Default: unset
PORT=8080

# Time the server waits to read the request headers before responding 408.
# Format: Go duration ("5s", "1m", "1h30m").
# Default: 5s
# GONEXT_SERVER_READ_HEADER_TIMEOUT=5s

# Total time allowed to read the entire request (headers + body).
# Default: 15s
# GONEXT_SERVER_READ_TIMEOUT=15s

# Time allowed to generate and flush the response.
# Default: 30s
# GONEXT_SERVER_WRITE_TIMEOUT=30s

# Idle keep-alive timeout between requests on the same connection.
# Default: 60s
# GONEXT_SERVER_IDLE_TIMEOUT=60s

# Drain window when SIGTERM arrives — long enough for in-flight requests
# to finish, short enough to keep deploys snappy.
# Default: 30s
# GONEXT_SERVER_SHUTDOWN_TIMEOUT=30s

# Maximum bytes per request header block. Guards against header smuggling
# and slowloris-shaped memory abuse. 1 MiB by default.
# Default: 1048576  (1 << 20)
# GONEXT_SERVER_MAX_HEADER_BYTES=1048576

# Comma-separated CIDRs of upstream proxies whose X-Forwarded-* headers we
# trust. Empty disables proxy-header processing entirely (safer default).
# Production: set to your reverse-proxy / CDN edge ranges.
# Default: unset (trust no upstream)
# GONEXT_TRUSTED_PROXIES=10.0.0.0/8,192.168.0.0/16

# ============================================================================
# Logging (packages/go/log)
# ============================================================================

# Log level. DEBUG | INFO | WARN | ERROR.
# Default: INFO
GONEXT_LOG_LEVEL=INFO

# Log format. json | text. Use "text" for human-readable dev logs; "json"
# for production log shippers.
# Default: json
GONEXT_LOG_FORMAT=json

# Emit the source file:line on every record. Useful in dev; small overhead
# in production.
# Default: false
# GONEXT_LOG_ADDSRC=false

# ============================================================================
# Database (Postgres)
# ============================================================================

# REQUIRED. libpq-style DSN.
# Format: postgres://user:password@host:port/database?sslmode=require
# Production: sslmode=require (or verify-full); never disable in prod.
# Redacted in `gonext config dump`.
DATABASE_URL=postgres://gonext:gonext_dev_only@localhost:5432/gonext_dev?sslmode=disable

# Connection pool ceiling. Defaults sized for one API replica @ ~100 RPS;
# bump to ~50 per replica in production after load testing.
# Default: 25
# GONEXT_DB_MAX_OPEN_CONNS=25

# Pool floor for idle connections.
# Default: 5
# GONEXT_DB_MAX_IDLE_CONNS=5

# Max connection lifetime before the pool retires it (mitigates Postgres
# memory creep and helps with rolling certificate rotations).
# Default: 30m
# GONEXT_DB_CONN_MAX_LIFETIME=30m

# Max idle time before an unused connection is closed.
# Default: 5m
# GONEXT_DB_CONN_MAX_IDLE_TIME=5m

# Postgres `statement_timeout` applied per connection. Long-running queries
# should override via context, not by raising this ceiling.
# Default: 30s
# GONEXT_DB_STATEMENT_TIMEOUT=30s

# Directory holding golang-migrate .sql files. In Docker images, point to
# the embedded path (e.g. "/migrations").
# Default: ./migrations
# GONEXT_MIGRATION_DIR=./migrations

# ============================================================================
# Redis
# ============================================================================

# Redis connection URL. Format: redis://[user:pass@]host:port/db
# May embed a password — redacted in `gonext config dump`.
# Production: must point at a managed Redis with auth + TLS (rediss://).
# Default: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Maximum total connections in the pool.
# Default: 20
# GONEXT_REDIS_POOL_SIZE=20

# Minimum idle connections kept warm.
# Default: 2
# GONEXT_REDIS_MIN_IDLE_CONNS=2

# Dial / read / write timeouts. Defaults shown.
# GONEXT_REDIS_DIAL_TIMEOUT=5s
# GONEXT_REDIS_READ_TIMEOUT=3s
# GONEXT_REDIS_WRITE_TIMEOUT=3s

# ============================================================================
# Object storage (S3-compatible)
# ============================================================================

# Endpoint URL. Empty uses AWS S3 default endpoint resolution. Set for
# MinIO, Cloudflare R2, Backblaze B2, LocalStack, or any S3-compatible
# provider.
# Default: unset (AWS default)
# AWS_ENDPOINT_URL=http://localhost:9000

# AWS region. Most S3-compatible providers accept any region string;
# leave at us-east-1 unless the provider documents otherwise.
# Default: us-east-1
AWS_REGION=us-east-1

# Bucket name. Must exist before first write.
# Default: gonext-media
GONEXT_S3_BUCKET=gonext-media

# Access credentials. REQUIRED when not running with an IAM role or
# AWS SSO. Both fields are redacted in `gonext config dump`.
# Production: prefer IAM Roles for Service Accounts (EKS) /
# Instance Profiles (EC2) over static keys.
AWS_ACCESS_KEY_ID=gonext
AWS_SECRET_ACCESS_KEY=gonext_dev_only_change_me

# Use HTTPS for S3 requests. Set false only for local MinIO over plain HTTP.
# Default: true
# GONEXT_S3_USE_SSL=true

# Path-style bucket addressing (https://endpoint/bucket/key). Required for
# MinIO; AWS S3 expects virtual-hosted-style (false).
# Default: false
# GONEXT_S3_PATH_STYLE=false

# ============================================================================
# Authentication (REQUIRED secrets)
# ============================================================================
#
# All three secrets are REQUIRED. The loader rejects any value below
# 32 bytes (after base64 decode if the value parses as base64, otherwise
# 32 chars raw). Generate fresh values per deployment:
#
#     openssl rand -base64 32
#
# Never commit production secrets. Use a secrets manager (HashiCorp Vault,
# AWS Secrets Manager, GCP Secret Manager, Kubernetes Secrets) in prod.
# All three are redacted in `gonext config dump`.
# Production: must be >=32 random bytes; rotate per docs/13-security-baseline.md §5.

# Pepper HMAC'd into the argon2id password-hash input.
GONEXT_AUTH_PEPPER=change-me-32-bytes-dev-only-AAAAAAAAAA==

# Session cookie signing secret.
GONEXT_AUTH_SESSION_SECRET=change-me-32-bytes-dev-only-BBBBBBBBBB==

# Anti-CSRF token signing secret (public-form variant).
GONEXT_AUTH_CSRF_SECRET=change-me-32-bytes-dev-only-CCCCCCCCCC==

# Session cookie absolute lifetime.
# Default: 720h (30 days)
# GONEXT_AUTH_SESSION_TTL=720h

# Session idle expiration. Cookies dropped after this much silence even
# if SessionTTL has not elapsed.
# Default: 168h (7 days)
# GONEXT_AUTH_SESSION_IDLE_TTL=168h

# ============================================================================
# Plugins
# ============================================================================
#
# DevMode + DevToken gate POST /_/plugins/dev/install — the hot-reload
# endpoint used by `gonext plugin dev`. The route is NOT REGISTERED when
# DevMode is false, so production deployments cannot expose it by
# accident. Leave DevMode=false on every public host.

# Enable the dev-install endpoint. Set true ONLY on developer workstations
# or sealed staging hosts where the watch loop runs.
# Default: false
# Production: must remain false.
# GONEXT_PLUGINS_DEV_MODE=false

# Shared secret the dev-install handler compares the Dev-Token request
# header against. Empty + DevMode=true means "reject every request"
# (a misconfigured dev box cannot accept uploads from random network
# peers). Redacted in `gonext config dump`.
# Default: unset
# GONEXT_PLUGINS_DEV_TOKEN=change-me-dev-only-shared-secret

# ============================================================================
# Performance
# ============================================================================

# HTTP 103 Early Hints middleware. When true, flushes a 103 interim
# response carrying Link: rel=preload for the active theme's stylesheet
# so browsers (Chrome 103+, Firefox 110+, Safari 17+) start fetching
# assets while the server is still working. Typically wins 50-200ms LCP.
#
# Disable only if a reverse proxy in front of GoNext drops 1xx interim
# responses (modern nginx, HAProxy, Cloudflare, AWS ALB all forward them
# correctly).
# Default: true
# GONEXT_PERFORMANCE_EARLY_HINTS=true

# ============================================================================
# RUM (Real User Monitoring)
# ============================================================================
#
# The beacon endpoint (POST /_/rum/beacon) is always mounted; the public
# theme only emits beacon scripts when Enabled is true. Flipping this
# off at runtime makes the rum_events table sit empty without a redeploy.

# Enable the public-theme beacon emitter.
# Default: false
# GONEXT_RUM_ENABLED=false

# Per-visitor browser-side sample probability in [0, 1]. The default 1.0
# samples every visitor; drop to e.g. 0.1 for a busy site that does not
# need every pageview's Core Web Vitals in Postgres.
# Default: 1.0
# GONEXT_RUM_SAMPLE_RATE=1.0

# ============================================================================
# Email (transactional outbound)
# ============================================================================
#
# Selects the packages/go/email.Sender wired into the chassis.
# Provider matrix:
#   smtp — production SMTP sender; requires HOST + FROM (USERNAME/PASSWORD
#          required together when set).
#   noop — in-memory recorder. Default; sends never go on the wire.
#   log  — renders messages to slog. "What would have been sent" debug.
#
# Backwards compatibility: GONEXT_EMAIL_* keys fall back to GONEXT_SMTP_*
# if the canonical key is unset (early-bootstrap env names).

# Transport selector. smtp | noop | log.
# Default: noop
# GONEXT_EMAIL_PROVIDER=noop

# SMTP server hostname. REQUIRED when Provider=smtp.
# Fallback key: GONEXT_SMTP_HOST.
# Default: unset
# GONEXT_EMAIL_HOST=smtp.example.com
# GONEXT_SMTP_HOST=smtp.example.com

# SMTP port. 587 = submission with STARTTLS (default). 465 = implicit TLS.
# 25 = legacy plaintext (do not use in production).
# Fallback key: GONEXT_SMTP_PORT.
# Default: 587
# GONEXT_EMAIL_PORT=587
# GONEXT_SMTP_PORT=587

# SASL identity. Empty disables AUTH entirely (open-relay-style internal
# deployments). Fallback key: GONEXT_SMTP_USER.
# Default: unset
# GONEXT_EMAIL_USERNAME=postmaster@example.com
# GONEXT_SMTP_USER=postmaster@example.com

# SASL secret. Redacted in `gonext config dump`. REQUIRED when USERNAME
# is set. Fallback key: GONEXT_SMTP_PASSWORD.
# Production: pull from secrets manager, do not bake into images.
# Default: unset
# GONEXT_EMAIL_PASSWORD=change-me-smtp-secret
# GONEXT_SMTP_PASSWORD=change-me-smtp-secret

# Default envelope-sender address. REQUIRED when Provider=smtp.
# Fallback key: GONEXT_SMTP_FROM.
# Default: unset
# GONEXT_EMAIL_FROM="GoNext <no-reply@example.com>"
# GONEXT_SMTP_FROM="GoNext <no-reply@example.com>"

# Implicit-TLS on connect (port 465). When false, STARTTLS on the
# configured Port (modern submission convention).
# Default: false
# GONEXT_EMAIL_TLS=false

# SMTP AUTH mechanism. plain | login | crammd5.
# Default: plain
# GONEXT_EMAIL_AUTH_MECH=plain

# Disable TLS certificate verification. DEV ONLY — production deployments
# MUST leave this false (else MITM-prone).
# Default: false
# Production: must remain false.
# GONEXT_EMAIL_INSECURE_SKIP_VERIFY=false

# TCP+TLS handshake budget.
# Default: 10s
# GONEXT_EMAIL_DIAL_TIMEOUT=10s

# Brand name stamped into every templated message ("Welcome to <BrandName>").
# Default: GoNext
# GONEXT_EMAIL_BRAND_NAME=GoNext

# CSS color literal used in HTML template headers and CTAs.
# Default: #2563eb
# GONEXT_EMAIL_BRAND_COLOR=#2563eb

# Canonical home URL used in template footers and the welcome sign-in
# button. Empty omits the link.
# Default: unset
# GONEXT_EMAIL_SITE_URL=https://example.com

# User-facing escalation address printed in password-reset bodies. Empty
# hides the "contact support" line.
# Default: unset
# GONEXT_EMAIL_SUPPORT=support@example.com

# ============================================================================
# Public site (apps/web renderer)
# ============================================================================

# Canonical origin the renderer stamps into sitemap <loc>, Atom <id> /
# <link rel="self">, and the robots.txt Sitemap: line. No trailing slash
# (the renderer concatenates paths directly). Empty disables every
# absolute-URL surface.
# Default: unset
# Production: set to the public origin (e.g. https://example.com).
# GONEXT_PUBLIC_SITE_BASE_URL=https://example.com

# Whether robots.txt allows search-engine crawling. The default depends
# on GONEXT_ENV: production => true; everything else => false (staging
# and dev hosts stay non-indexable by default).
# Default: (GONEXT_ENV == production)
# GONEXT_PUBLIC_SITE_ALLOW_INDEX=true
