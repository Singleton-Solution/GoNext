# GoNext environment variables — comprehensive reference.
#
# Copy this file to .env for local development:
#     cp .env.example .env
#
# The .env file is gitignored. Never commit secrets.
#
# Required variables have no default. The process refuses to boot if any
# required variable is missing. Optional variables have sensible defaults
# documented inline.
#
# See packages/go/config/ for the loader and validation rules.
# See docs/13-security-baseline.md §5 for secret management policy.

# ============================================================================
# Environment
# ============================================================================

# Deployment environment. One of: development, staging, production, test.
# Unknown values are treated as "development". Defaults to "development".
GONEXT_ENV=development

# ============================================================================
# HTTP server (apps/api)
# ============================================================================

# Listen address. Honored as "host:port" or ":port" (bind all interfaces).
# If unset, falls back to PORT if set, then ":8080".
# GONEXT_SERVER_ADDR=":8080"
PORT=8080

# Server timeouts. Defaults shown.
# GONEXT_SERVER_READ_HEADER_TIMEOUT=5s
# GONEXT_SERVER_READ_TIMEOUT=15s
# GONEXT_SERVER_WRITE_TIMEOUT=30s
# GONEXT_SERVER_IDLE_TIMEOUT=60s
# GONEXT_SERVER_SHUTDOWN_TIMEOUT=30s

# Max header bytes per request. Default 1 MiB. Helps mitigate header smuggling.
# GONEXT_SERVER_MAX_HEADER_BYTES=1048576

# Comma-separated CIDRs of upstream proxies whose X-Forwarded-* headers we trust.
# Empty by default. Set to your reverse proxy / CDN ranges in production.
# GONEXT_TRUSTED_PROXIES="10.0.0.0/8,192.168.0.0/16"

# ============================================================================
# Logging (packages/go/log)
# ============================================================================

# Log level. DEBUG | INFO | WARN | ERROR. Default INFO.
GONEXT_LOG_LEVEL=INFO

# Log format. json | text. Default json. Use text for human-readable dev logs.
GONEXT_LOG_FORMAT=json

# Emit the source file:line on every log. Default off (overhead).
# GONEXT_LOG_ADDSRC=false

# ============================================================================
# Database (Postgres)
# ============================================================================

# REQUIRED. libpq-style DSN.
# Format: postgres://user:password@host:port/database?sslmode=...
DATABASE_URL=postgres://gonext:gonext_dev_only@localhost:5432/gonext_dev?sslmode=disable

# Connection pool. Defaults are sized for a single API replica @ ~100 RPS.
# Bump MaxOpenConns up to ~50 per replica in production after load testing.
# GONEXT_DB_MAX_OPEN_CONNS=25
# GONEXT_DB_MAX_IDLE_CONNS=5
# GONEXT_DB_CONN_MAX_LIFETIME=30m
# GONEXT_DB_CONN_MAX_IDLE_TIME=5m

# Postgres statement_timeout. Default 30s. Long-running queries should
# explicitly extend via context, not by raising this.
# GONEXT_DB_STATEMENT_TIMEOUT=30s

# Directory holding golang-migrate .sql files. Default "./migrations".
# In Docker images, set to the embedded path (e.g., "/migrations").
# GONEXT_MIGRATION_DIR=./migrations

# ============================================================================
# Redis
# ============================================================================

# Redis connection URL. Default points at the docker-compose redis.
# Format: redis://[user:pass@]host:port/db
REDIS_URL=redis://localhost:6379/0

# Connection pool. Defaults are reasonable for typical workloads.
# GONEXT_REDIS_POOL_SIZE=20
# GONEXT_REDIS_MIN_IDLE_CONNS=2
# GONEXT_REDIS_DIAL_TIMEOUT=5s
# GONEXT_REDIS_READ_TIMEOUT=3s
# GONEXT_REDIS_WRITE_TIMEOUT=3s

# ============================================================================
# Object storage (S3-compatible)
# ============================================================================

# Endpoint URL. Empty (default) uses AWS S3 default endpoint resolution.
# Set this for MinIO, R2, Backblaze B2, or any S3-compatible provider.
# AWS_ENDPOINT_URL=http://localhost:9000

# AWS region. Default us-east-1.
AWS_REGION=us-east-1

# Bucket name. Default "gonext-media".
GONEXT_S3_BUCKET=gonext-media

# Credentials. Required when not running with an IAM role or AWS SSO.
# For docker-compose / MinIO, use the dev credentials from docker-compose.yml.
AWS_ACCESS_KEY_ID=gonext
AWS_SECRET_ACCESS_KEY=gonext_dev_only_change_me

# Use SSL. Default true. Set false for plain-HTTP MinIO in dev.
# GONEXT_S3_USE_SSL=true

# Path-style addressing. Required for MinIO; off for AWS S3.
# GONEXT_S3_PATH_STYLE=true

# ============================================================================
# Authentication (REQUIRED secrets)
# ============================================================================
#
# All three secrets are REQUIRED, must be ≥32 bytes after base64 decode (if
# base64-formatted) OR ≥32 chars raw. Generate fresh values in production:
#
#     openssl rand -base64 32
#
# Never commit production secrets. Use a secrets manager (Vault, AWS SM,
# K8s Secrets) in production. See docs/13-security-baseline.md §5.

# Pepper HMAC'd into argon2id password hash input.
GONEXT_AUTH_PEPPER=replace-me-with-openssl-rand-base64-32-DEV-ONLY-XXX==

# Session cookie signing secret.
GONEXT_AUTH_SESSION_SECRET=replace-me-with-openssl-rand-base64-32-DEV-ONLY-YYY==

# Anti-CSRF token signing secret (public-form variant).
GONEXT_AUTH_CSRF_SECRET=replace-me-with-openssl-rand-base64-32-DEV-ONLY-ZZZ==

# Session lifetime. Defaults: TTL 30 days, idle TTL 7 days.
# GONEXT_AUTH_SESSION_TTL=720h
# GONEXT_AUTH_SESSION_IDLE_TTL=168h
