{
  "$schema": "https://gonext.dev/schemas/theme.json/v1",
  "version": 1,
  "title": "GoNext Pro",
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "ink",         "name": "Ink",            "color": "#0E1A14" },
        { "slug": "ink-muted",   "name": "Ink Muted",      "color": "#4A5C52" },
        { "slug": "paper",       "name": "Paper",          "color": "#F5F2EA" },
        { "slug": "paper-muted", "name": "Paper Muted",    "color": "#EFEBE0" },
        { "slug": "rule",        "name": "Rule",           "color": "#D9D2C0" },
        { "slug": "accent",      "name": "Accent",         "color": "#10B981" },
        { "slug": "accent-fg",   "name": "On Accent",      "color": "#022C22" },
        { "slug": "success",     "name": "Success",        "color": "#059669" },
        { "slug": "warning",     "name": "Warning",        "color": "#D97706" },
        { "slug": "danger",      "name": "Danger",         "color": "#DC2626" }
      ],
      "gradients": [
        { "slug": "emerald-glow",  "name": "Emerald Glow",  "gradient": "radial-gradient(circle, #34D399 0%, #10B981 100%)" },
        { "slug": "lavender-glow", "name": "Lavender Glow", "gradient": "radial-gradient(circle, #A78BFA 0%, #7C3AED 100%)" },
        { "slug": "forest-pulse",  "name": "Forest Pulse",  "gradient": "linear-gradient(135deg, #0E1A14 0%, #18261E 60%, #22322A 100%)" },
        { "slug": "dawn",          "name": "Dawn",          "gradient": "linear-gradient(135deg, #EFEBE0 0%, #F5F2EA 50%, #D1FAE5 100%)" }
      ],
      "custom": true,
      "customGradient": true,
      "defaultPalette": false,
      "duotone": []
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "display",
          "name": "Display",
          "fontFamily": "Archivo, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif"
        },
        {
          "slug": "sans",
          "name": "Sans",
          "fontFamily": "Geist, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif"
        },
        {
          "slug": "mono",
          "name": "Mono",
          "fontFamily": "Geist Mono, ui-monospace, SFMono-Regular, Menlo, monospace"
        }
      ],
      "fontSizes": [
        { "slug": "xs",  "name": "X-Small",  "size": "0.75rem" },
        { "slug": "sm",  "name": "Small",    "size": "0.875rem" },
        { "slug": "md",  "name": "Medium",   "size": "1rem" },
        { "slug": "lg",  "name": "Large",    "size": "1.25rem" },
        { "slug": "xl",  "name": "X-Large",  "size": "1.75rem" },
        { "slug": "xxl", "name": "Display",  "size": "2.75rem",
          "fluid": { "min": "2.25rem", "max": "4rem" } }
      ],
      "lineHeight": true,
      "letterSpacing": true,
      "textDecoration": true,
      "custom": true
    },
    "spacing": {
      "units": ["px", "rem", "em", "%", "vw"],
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 5,
        "mediumStep": 1,
        "unit": "rem"
      },
      "padding": true,
      "margin": true,
      "blockGap": true
    },
    "layout": {
      "contentSize": "720px",
      "wideSize": "1180px"
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "shadow": {
      "presets": [
        { "slug": "soft",   "name": "Soft",   "shadow": "0 1px 2px rgba(14, 26, 20, 0.04)" },
        { "slug": "lifted", "name": "Lifted", "shadow": "0 6px 14px -4px rgba(14, 26, 20, 0.08), 0 2px 6px -2px rgba(14, 26, 20, 0.04)" },
        { "slug": "deep",   "name": "Deep",   "shadow": "0 16px 32px -10px rgba(14, 26, 20, 0.14), 0 4px 10px -4px rgba(14, 26, 20, 0.06)" }
      ]
    },
    "blocks": {
      "core/button": {
        "border": { "radius": true },
        "color": { "background": true, "text": true }
      },
      "core/image": {
        "border": { "radius": true }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp-preset--color--paper)",
      "text": "var(--wp-preset--color--ink)"
    },
    "typography": {
      "fontFamily": "var(--wp-preset--font-family--sans)",
      "fontSize": "var(--wp-preset--font-size--md)",
      "lineHeight": "1.65"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp-preset--font-family--display)",
          "fontSize": "var(--wp-preset--font-size--xxl)",
          "lineHeight": "1.0"
        },
        "color": { "text": "var(--wp-preset--color--ink)" }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp-preset--font-family--display)",
          "fontSize": "var(--wp-preset--font-size--xl)",
          "lineHeight": "1.15"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp-preset--font-family--sans)",
          "fontSize": "var(--wp-preset--font-size--lg)",
          "lineHeight": "1.25"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp-preset--font-family--sans)",
          "fontSize": "var(--wp-preset--font-size--md)",
          "lineHeight": "1.4"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp-preset--font-family--sans)",
          "fontSize": "var(--wp-preset--font-size--sm)",
          "lineHeight": "1.4"
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp-preset--font-family--sans)",
          "fontSize": "var(--wp-preset--font-size--xs)",
          "lineHeight": "1.4"
        }
      },
      "a": {
        "color": { "text": "var(--wp-preset--color--accent)" }
      },
      "button": {
        "color": {
          "background": "var(--wp-preset--color--accent)",
          "text": "var(--wp-preset--color--accent-fg)"
        }
      }
    },
    "blocks": {
      "core/button": {
        "color": {
          "background": "var(--wp-preset--color--accent)",
          "text": "var(--wp-preset--color--accent-fg)"
        },
        "border": { "radius": "0.5rem" }
      }
    }
  },
  "supports": {
    "blockTemplates": true,
    "siteEditor": true,
    "darkModeAuto": true,
    "customizer": true,
    "menus": ["primary", "footer", "social"],
    "widgetAreas": ["sidebar-main", "footer-1", "footer-2", "footer-3"]
  },
  "patterns": [],
  "customTemplates": [
    { "name": "page-landing", "title": "Landing Page", "postTypes": ["page"] },
    { "name": "page-wide",    "title": "Wide Page",    "postTypes": ["page"] }
  ],
  "templateParts": [
    { "name": "header",    "title": "Header",    "area": "header" },
    { "name": "footer",    "title": "Footer",    "area": "footer" },
    { "name": "sidebar",   "title": "Sidebar",   "area": "sidebar" },
    { "name": "comments",  "title": "Comments",  "area": "uncategorized" },
    { "name": "post-meta", "title": "Post Meta", "area": "uncategorized" }
  ]
}
