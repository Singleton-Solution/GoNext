{
  "$schema": "https://gonext.dev/schemas/theme.json/v1",
  "version": 1,
  "title": "GoNext Pro",
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "ink",          "name": "Ink",            "color": "#0b1220" },
        { "slug": "ink-muted",    "name": "Ink Muted",      "color": "#475569" },
        { "slug": "paper",        "name": "Paper",          "color": "#ffffff" },
        { "slug": "paper-muted",  "name": "Paper Muted",    "color": "#f8fafc" },
        { "slug": "rule",         "name": "Rule",           "color": "#e2e8f0" },
        { "slug": "accent",       "name": "Accent",         "color": "#2563eb" },
        { "slug": "accent-fg",    "name": "On Accent",      "color": "#ffffff" },
        { "slug": "success",      "name": "Success",        "color": "#16a34a" },
        { "slug": "warning",      "name": "Warning",        "color": "#d97706" },
        { "slug": "danger",       "name": "Danger",         "color": "#dc2626" }
      ],
      "gradients": [
        { "slug": "sunrise", "name": "Sunrise", "gradient": "linear-gradient(135deg, #fde68a, #f97316)" },
        { "slug": "dusk",    "name": "Dusk",    "gradient": "linear-gradient(135deg, #4338ca, #7c3aed)" },
        { "slug": "ocean",   "name": "Ocean",   "gradient": "linear-gradient(135deg, #0ea5e9, #2563eb)" },
        { "slug": "forest",  "name": "Forest",  "gradient": "linear-gradient(135deg, #16a34a, #0f766e)" }
      ],
      "custom": true,
      "customGradient": true,
      "defaultPalette": false,
      "duotone": []
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "sans",
          "name": "Sans",
          "fontFamily": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif"
        },
        {
          "slug": "serif",
          "name": "Serif",
          "fontFamily": "Iowan Old Style, Apple Garamond, Baskerville, Times New Roman, serif"
        },
        {
          "slug": "mono",
          "name": "Mono",
          "fontFamily": "JetBrains Mono, ui-monospace, SFMono-Regular, Menlo, monospace"
        }
      ],
      "fontSizes": [
        { "slug": "xs",  "name": "X-Small",  "size": "0.75rem" },
        { "slug": "sm",  "name": "Small",    "size": "0.875rem" },
        { "slug": "md",  "name": "Medium",   "size": "1rem" },
        { "slug": "lg",  "name": "Large",    "size": "1.25rem" },
        { "slug": "xl",  "name": "X-Large",  "size": "1.75rem" },
        { "slug": "xxl", "name": "Display",  "size": "2.5rem",
          "fluid": { "min": "2rem", "max": "3.5rem" } }
      ],
      "lineHeight": true,
      "letterSpacing": true,
      "textDecoration": true,
      "custom": true
    },
    "spacing": {
      "units": ["px", "rem", "em", "%", "vw"],
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 5,
        "mediumStep": 1,
        "unit": "rem"
      },
      "padding": true,
      "margin": true,
      "blockGap": true
    },
    "layout": {
      "contentSize": "720px",
      "wideSize": "1180px"
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "shadow": {
      "presets": [
        { "slug": "soft",   "name": "Soft",   "shadow": "0 1px 2px rgba(15, 23, 42, 0.05)" },
        { "slug": "lifted", "name": "Lifted", "shadow": "0 8px 24px rgba(15, 23, 42, 0.12)" },
        { "slug": "deep",   "name": "Deep",   "shadow": "0 24px 48px rgba(15, 23, 42, 0.18)" }
      ]
    },
    "blocks": {
      "core/button": {
        "border": { "radius": true },
        "color": { "background": true, "text": true }
      },
      "core/image": {
        "border": { "radius": true }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp-preset--color--paper)",
      "text": "var(--wp-preset--color--ink)"
    },
    "typography": {
      "fontFamily": "var(--wp-preset--font-family--sans)",
      "fontSize": "var(--wp-preset--font-size--md)",
      "lineHeight": "1.6"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp-preset--font-family--serif)",
          "fontSize": "var(--wp-preset--font-size--xxl)",
          "lineHeight": "1.1"
        },
        "color": { "text": "var(--wp-preset--color--ink)" }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp-preset--font-family--serif)",
          "fontSize": "var(--wp-preset--font-size--xl)",
          "lineHeight": "1.2"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp-preset--font-family--sans)",
          "fontSize": "var(--wp-preset--font-size--lg)",
          "lineHeight": "1.3"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp-preset--font-family--sans)",
          "fontSize": "var(--wp-preset--font-size--md)",
          "lineHeight": "1.4"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp-preset--font-family--sans)",
          "fontSize": "var(--wp-preset--font-size--sm)",
          "lineHeight": "1.4"
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp-preset--font-family--sans)",
          "fontSize": "var(--wp-preset--font-size--xs)",
          "lineHeight": "1.4"
        }
      },
      "a": {
        "color": { "text": "var(--wp-preset--color--accent)" }
      },
      "button": {
        "color": {
          "background": "var(--wp-preset--color--accent)",
          "text": "var(--wp-preset--color--accent-fg)"
        }
      }
    },
    "blocks": {
      "core/button": {
        "color": {
          "background": "var(--wp-preset--color--accent)",
          "text": "var(--wp-preset--color--accent-fg)"
        },
        "border": { "radius": "0.5rem" }
      }
    }
  },
  "supports": {
    "blockTemplates": true,
    "siteEditor": true,
    "darkModeAuto": true,
    "customizer": true,
    "menus": ["primary", "footer", "social"],
    "widgetAreas": ["sidebar-main", "footer-1", "footer-2", "footer-3"]
  },
  "patterns": [],
  "customTemplates": [
    { "name": "page-landing", "title": "Landing Page", "postTypes": ["page"] },
    { "name": "page-wide",    "title": "Wide Page",    "postTypes": ["page"] }
  ],
  "templateParts": [
    { "name": "header",    "title": "Header",    "area": "header" },
    { "name": "footer",    "title": "Footer",    "area": "footer" },
    { "name": "sidebar",   "title": "Sidebar",   "area": "sidebar" },
    { "name": "comments",  "title": "Comments",  "area": "uncategorized" },
    { "name": "post-meta", "title": "Post Meta", "area": "uncategorized" }
  ]
}
