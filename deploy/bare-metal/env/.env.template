# GoNext bare-metal environment file.
#
# This template is a thin wrapper around the canonical .env.example at the
# repository root. Copy it to /etc/gonext/.env, fill in the REQUIRED values,
# then `chown root:gonext` and `chmod 0640` so only the gonext service user
# can read it.
#
# For the comprehensive variable reference and defaults, see:
#   - /usr/share/doc/gonext/.env.example  (installed by install.sh)
#   - https://github.com/Singleton-Solution/GoNext/blob/main/.env.example
#   - docs/09-deployment-ops.md §7
#
# Anything not listed here keeps its default from packages/go/config.

# ============================================================================
# Environment
# ============================================================================
GONEXT_ENV=production

# ============================================================================
# HTTP server
# ============================================================================
# Listen on loopback only — Caddy is the only public listener on a
# bare-metal box.
GONEXT_SERVER_ADDR=127.0.0.1:8080

# CIDRs of upstream proxies whose X-Forwarded-* headers we trust. For a
# single-box install where Caddy talks to the API over loopback, this is
# 127.0.0.0/8.
GONEXT_TRUSTED_PROXIES=127.0.0.0/8,::1/128

# ============================================================================
# Logging
# ============================================================================
GONEXT_LOG_LEVEL=INFO
GONEXT_LOG_FORMAT=json

# ============================================================================
# Database (Postgres) — REQUIRED
# ============================================================================
# Created by install.sh against the OS-package Postgres on the same host.
# Replace `REPLACE_ME` with the password install.sh generated.
DATABASE_URL=postgres://gonext:REPLACE_ME@127.0.0.1:5432/gonext?sslmode=disable

# ============================================================================
# Redis
# ============================================================================
REDIS_URL=redis://127.0.0.1:6379/0

# ============================================================================
# Object storage — OPTIONAL on bare-metal
# ============================================================================
# Leave AWS_* empty and rely on local-disk media under /var/lib/gonext/media
# until you outgrow the box. When you switch to S3/R2/Backblaze, fill these
# in and run `gonext migrate-media` to copy existing files.
#
# AWS_ENDPOINT_URL=
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# GONEXT_S3_BUCKET=gonext-media

# ============================================================================
# Authentication — REQUIRED secrets
# ============================================================================
# install.sh generates these with `openssl rand -base64 32`. Never reuse a
# secret across environments and never commit production values.
GONEXT_AUTH_PEPPER=REPLACE_ME_openssl_rand_base64_32
GONEXT_AUTH_SESSION_SECRET=REPLACE_ME_openssl_rand_base64_32
GONEXT_AUTH_CSRF_SECRET=REPLACE_ME_openssl_rand_base64_32
