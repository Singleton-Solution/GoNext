{
  "title": "GoNext — Jobs (Asynq)",
  "uid": "gonext-jobs",
  "tags": ["gonext", "jobs", "asynq"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {"text": "Prometheus", "value": "Prometheus"},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "env",
        "label": "Environment",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(gonext_jobs_processed_total, env)",
        "current": {"text": "All", "value": "$__all"},
        "includeAll": true,
        "multi": false,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "queue",
        "label": "Queue",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(gonext_jobs_processed_total{env=~\"$env\"}, queue)",
        "current": {"text": "All", "value": "$__all"},
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total processed/s",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(gonext_jobs_processed_total{env=~\"$env\",queue=~\"$queue\"}[5m]))",
          "legendFormat": "processed/s"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total failed/s",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 5}
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(gonext_jobs_failed_total{env=~\"$env\",queue=~\"$queue\"}[5m]))",
          "legendFormat": "failed/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Inflight",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(gonext_jobs_inflight{env=~\"$env\",queue=~\"$queue\"})",
          "legendFormat": "inflight"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Unknown tasks/s",
      "description": "Tasks routed to NotFound handler — usually indicates code/deploy skew.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.1}
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(gonext_jobs_unknown_total{env=~\"$env\",queue=~\"$queue\"}[5m]))",
          "legendFormat": "unknown/s"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Processed rate by queue",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue) (rate(gonext_jobs_processed_total{env=~\"$env\",queue=~\"$queue\"}[1m]))",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Failed rate by queue",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue) (rate(gonext_jobs_failed_total{env=~\"$env\",queue=~\"$queue\"}[1m]))",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Inflight by queue",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue) (gonext_jobs_inflight{env=~\"$env\",queue=~\"$queue\"})",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Backpressure shed by queue/priority",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue, priority) (rate(gonext_backpressure_shed_total{env=~\"$env\",queue=~\"$queue\"}[1m]))",
          "legendFormat": "{{queue}} / {{priority}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Queue depth (gonext_asynq_queue_depth, when wired)",
      "description": "Documented in 10-observability.md §5.3. Emitted by the Asynq queue scraper.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue) (gonext_asynq_queue_depth{env=~\"$env\",queue=~\"$queue\"})",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 21,
      "type": "stat",
      "title": "DLQ size",
      "description": "From gonext_asynq_dlq_size when emitted. Empty until the queue scraper is wired.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 20},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 50}
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(gonext_asynq_dlq_size{env=~\"$env\"})",
          "legendFormat": "dlq"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Retry rate (gonext_asynq_job_retries_total, when wired)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 20},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(gonext_asynq_job_retries_total{env=~\"$env\"}[5m]))",
          "legendFormat": "retries/s"
        }
      ]
    }
  ]
}
