{
  "title": "GoNext — Overview",
  "uid": "gonext-overview",
  "tags": ["gonext", "overview"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {"text": "Prometheus", "value": "Prometheus"},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "env",
        "label": "Environment",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(gonext_http_requests_total, env)",
        "current": {"text": "All", "value": "$__all"},
        "includeAll": true,
        "multi": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request rate (req/s)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {"unit": "reqps", "decimals": 2}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(gonext_http_requests_total{env=~\"$env\"}[5m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error rate (5xx)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.005},
              {"color": "red", "value": 0.01}
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(gonext_http_requests_total{env=~\"$env\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(gonext_http_requests_total{env=~\"$env\"}[5m])), 1)",
          "legendFormat": "5xx ratio"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "p95 latency",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {"unit": "s", "decimals": 3}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gonext_http_request_duration_seconds_bucket{env=~\"$env\"}[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Inflight requests",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "value"
      },
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(gonext_http_inflight_requests{env=~\"$env\"})",
          "legendFormat": "inflight"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Request rate by status class",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(gonext_http_requests_total{env=~\"$env\"}[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HTTP latency p50 / p95 / p99",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(gonext_http_request_duration_seconds_bucket{env=~\"$env\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gonext_http_request_duration_seconds_bucket{env=~\"$env\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(gonext_http_request_duration_seconds_bucket{env=~\"$env\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Jobs processed vs failed (per second)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(gonext_jobs_processed_total{env=~\"$env\"}[1m]))",
          "legendFormat": "processed/s"
        },
        {
          "refId": "B",
          "expr": "sum(rate(gonext_jobs_failed_total{env=~\"$env\"}[1m]))",
          "legendFormat": "failed/s"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Jobs inflight by queue",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue) (gonext_jobs_inflight{env=~\"$env\"})",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Plugin invocations (per second)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(gonext_plugin_invocations_total{env=~\"$env\"}[1m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Backpressure shed (per second)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "options": {"legend": {"displayMode": "table", "placement": "right"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue) (rate(gonext_backpressure_shed_total{env=~\"$env\"}[1m]))",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 40,
      "type": "stat",
      "title": "Build version",
      "description": "Reads gonext_build_info{version=\"...\"} when emitted; otherwise shows N/A.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 28},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "/^version$/"},
        "textMode": "value_and_name",
        "colorMode": "none"
      },
      "fieldConfig": {"defaults": {"unit": "none"}},
      "targets": [
        {
          "refId": "A",
          "expr": "gonext_build_info{env=~\"$env\"}",
          "legendFormat": "{{version}}",
          "instant": true,
          "format": "table"
        }
      ]
    }
  ]
}
