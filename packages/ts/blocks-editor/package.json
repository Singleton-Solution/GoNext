{
  "name": "@gonext/blocks-editor",
  "version": "0.0.0",
  "private": false,
  "description": "Minimal block-editor scaffold for GoNext. Ships <BlockInserter> and <BlockEditCanvas> React components plus `defaultCoreBlocks` registration helpers on top of @gonext/blocks-sdk. Client-only — server-component-safe wrappers live in the consuming app. Apache-2.0.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "echo '@gonext/blocks-editor: source-only package, no build step'",
    "lint": "echo '@gonext/blocks-editor lint: not yet implemented'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@gonext/blocks-sdk": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@gonext/test-config": "workspace:*",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "jsdom": "^24.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0"
  }
}
