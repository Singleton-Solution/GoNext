{
  "name": "@gonext/hooks-schemas",
  "version": "0.0.0",
  "private": false,
  "description": "JSON Schema contracts for the GoNext hook bus. Mirrors packages/go/hooks/schemas so plugin guests (TS) and the host (Go) validate identical payload shapes. Apache-2.0.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas/*": "./src/schemas/*"
  },
  "files": [
    "src",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "echo '@gonext/hooks-schemas: source-only package, no build step'",
    "lint": "echo '@gonext/hooks-schemas lint: not yet implemented'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "sync-schemas": "node scripts/sync-schemas.mjs"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@gonext/test-config": "workspace:*",
    "@vitest/coverage-v8": "^1.6.0",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0"
  }
}
