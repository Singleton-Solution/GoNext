# Keep the Docker build context small. Anything we don't need in the
# builder stage should be listed here — it shaves seconds off `docker build`
# and avoids leaking local-only files into the image.

# Version control
.git
.gitignore
.gitattributes

# Editors / OS
.vscode
.idea
.DS_Store
Thumbs.db
*.swp
*.swo

# Node / pnpm
node_modules
.pnpm-store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# JS build output
dist
build
out
.next

# Go build artifacts (workspace-mode lands binaries next to main.go)
bin
apps/api/server
apps/worker/worker
cli/gonext/gonext
*.test
*.out
go.work.sum

# Test / coverage
coverage
.nyc_output
*.cover
test-results
playwright-report

# Local env / secrets — never copy these into an image
.env
.env.local
.env.*.local

# Local dev scratch
.dev
tmp
*.local

# Docker / CI metadata not needed by the build
.github
.dockerignore
docker-compose.yml
docker-compose.*.yml

# Docs — not needed at build time (we still embed migrations & schemas
# from /migrations and /packages via go:embed when applicable)
docs
adr
*.md
!apps/*/README.md
!packages/**/README.md
